# Secrets and credentials — never commit these
*.pem
*.key
*.p12
*.pfx
*.env
.env.*
!.env.example

# Terraform state and variable files (may contain secrets)
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
.terraform/
.terraform.lock.hcl

# OS noise
.DS_Store
Thumbs.db

# Editor directories
.idea/
.vscode/
*.swp
*.swo
